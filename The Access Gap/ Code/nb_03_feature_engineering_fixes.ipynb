# FIX 4 — Safe Target Encoding

Replace your entire Cell 22 with this.

```python
# ── 3c. Target encoding of GEODGHR4 ─────────────────────────────────────────

# RESET INDICES FOR SAFE ALIGNMENT
X_train_fe = X_train_fe.reset_index(drop=True)
X_val_fe   = X_val_fe.reset_index(drop=True)
X_test_fe  = X_test_fe.reset_index(drop=True)

y_train = y_train.reset_index(drop=True)
y_val   = y_val.reset_index(drop=True)
y_test  = y_test.reset_index(drop=True)

# VALIDATION
assert len(X_train_fe) == len(y_train)
assert len(X_val_fe) == len(y_val)
assert len(X_test_fe) == len(y_test)

# Build TE dataframe
te_df = pd.DataFrame({
    'GEODGHR4': X_train_fe['GEODGHR4'],
    'target': y_train
})

# Global training mean
global_mean = float(y_train.mean())

# Compute training-only target encoding
geodghr4_target_enc = (
    te_df
    .groupby('GEODGHR4')['target']
    .mean()
    .to_dict()
)

# Apply mapping
X_train_fe['geodghr4_target_enc'] = (
    X_train_fe['GEODGHR4']
    .map(geodghr4_target_enc)
    .fillna(global_mean)
)

X_val_fe['geodghr4_target_enc'] = (
    X_val_fe['GEODGHR4']
    .map(geodghr4_target_enc)
    .fillna(global_mean)
)

X_test_fe['geodghr4_target_enc'] = (
    X_test_fe['GEODGHR4']
    .map(geodghr4_target_enc)
    .fillna(global_mean)
)

# Save mapping
te_manifest = {
    'global_mean': global_mean,
    'mapping': {
        str(k): float(v)
        for k, v in geodghr4_target_enc.items()
    }
}

with open(cfg.DATA_PROCESSED / 'geodghr4_target_encoding.json', 'w') as f:
    json.dump(te_manifest, f, indent=2)

print(f'Target encoding computed from {len(geodghr4_target_enc)} regions')
print(f'Global mean: {global_mean:.4f}')
print('Leakage check PASSED ✓')
```

