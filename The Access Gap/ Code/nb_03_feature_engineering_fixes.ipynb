## WITH THIS:

```python
# ── Merge regional features into split dataframes ───────────────────────────

REGIONAL_COLS = [
    'prov_total_facilities',
    'prov_hospitals',
    'prov_ambulatory',
    'prov_facilities_per_100k',
    'prov_hospitals_per_100k',
    'prov_ambulatory_per_100k'
]

# CRITICAL FIX:
# Ensure province table has ONE ROW PER GEOGPRV
prov_features_clean = (
    prov_features
    .drop_duplicates(subset='GEOGPRV')
    .copy()
)

print('Province table uniqueness check:')
print(prov_features_clean['GEOGPRV'].value_counts().head())

assert prov_features_clean['GEOGPRV'].is_unique, \
    'prov_features still contains duplicate provinces!'


def add_regional_features(X, prov_features, regional_cols):
    """
    SAFE left join.
    Preserves row count exactly.
    """

    before_rows = len(X)

    merge_cols = ['GEOGPRV'] + regional_cols

    X_out = X.merge(
        prov_features[merge_cols],
        on='GEOGPRV',
        how='left',
        validate='many_to_one'  # prevents row explosion
    )

    after_rows = len(X_out)

    assert before_rows == after_rows, \
        f'Row explosion detected! {before_rows} -> {after_rows}'

    return X_out


X_train_fe = add_regional_features(
    X_train_fe,
    prov_features_clean,
    REGIONAL_COLS
)

X_val_fe = add_regional_features(
    X_val_fe,
    prov_features_clean,
    REGIONAL_COLS
)

X_test_fe = add_regional_features(
    X_test_fe,
    prov_features_clean,
    REGIONAL_COLS
)

print(f'Train shape after regional merge: {X_train_fe.shape}')
print(f'Val shape after regional merge:   {X_val_fe.shape}')
print(f'Test shape after regional merge:  {X_test_fe.shape}')

print()
print('Regional NaN check:')
print(X_train_fe[REGIONAL_COLS].isnull().sum())

# FINAL SAFETY CHECKS
assert len(X_train_fe) == len(y_train)
assert len(X_val_fe) == len(y_val)
assert len(X_test_fe) == len(y_test)

print('\nRegional merge PASSED ✓')
```

